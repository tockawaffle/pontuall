{
	"productName": "PontuAll",
	"version": "0.2.0",
	"identifier": "com.tockanest.pontuall",
	"build": {
		"beforeDevCommand": "bun run sidecar:build && bun run dev",
		"beforeBuildCommand": "bun run sidecar:build && bun run build",
		"devUrl": "http://localhost:3000",
		"frontendDist": "../out"
	},
	"app": {
		"withGlobalTauri": false,
		"windows": [
			{
				"label": "splashscreen",
				"title": "PontuAll — Configuração",
				"width": 920,
				"height": 640,
				"minWidth": 880,
				"minHeight": 580,
				"resizable": true,
				"visible": true,
				"url": "/splashscreen",
				"center": true,
				"closable": false
			}
		],
		"security": {
			"csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/clock.ico"
		],
		"externalBin": [
			"binaries/pontuall-auth"
		],
		"windows": {
			"signCommand": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/sign.ps1 %1"
		}
	}
}
