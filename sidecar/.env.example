# BetterAuth sidecar environment
#
# In the packaged app you do NOT set any of these: the Rust backend injects
# all four when it spawns the sidecar (see src-tauri/src/auth/sidecar.rs),
# pulling DATABASE_URL / BETTER_AUTH_SECRET from the Windows Credential
# Manager and generating PORT / PONTUALL_SHARED_KEY per launch.
#
# This file only matters if you run the sidecar standalone for debugging:
#   cd sidecar && cp .env.example .env && bun run dev
# Bun auto-loads .env from this directory.

# Port the sidecar listens on (binds all interfaces so employees can open
# the e-mailed password-setup page from their own devices).
PORT=3435

# Optional: stable base URL used in e-mailed password-setup links (and
# trusted as a browser origin) when running the sidecar STANDALONE. In the
# packaged app configure this in Settings → Segurança → Avançado instead —
# the value stored there is sent with each request and overrides this env.
# No trailing slash.
# PONTUALL_PUBLIC_URL=https://ponto.suaempresa.com.br

# PostgreSQL connection string pointing at the application database
# (pontuall_{app_name}). Include credentials here.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pontuall_dev

# BetterAuth signing secret. Use 32+ random bytes in hex; generate with:
#   openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-32-bytes-hex

# Shared key the sidecar requires in the `x-pontuall-key` header on every
# /internal request. In production this is ephemeral per launch. For standalone
# testing pick any non-empty value and send it with your requests. The gate
# fails closed: an empty key rejects all /internal routes (the /api/auth
# endpoints stay reachable, so login/debugging still works without a key).
PONTUALL_SHARED_KEY=dev-shared-key

# Optional: SMTP for standalone sidecar testing of punch OTP e-mails.
# In the packaged app, SMTP is configured in Settings and sent per request.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=PontuAll <noreply@example.com>
